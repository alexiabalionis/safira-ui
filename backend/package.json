{
  "name": "safira-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Backend API para automacao de postos Safira",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "NODE_TLS_REJECT_UNAUTHORIZED=0 tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "NODE_TLS_REJECT_UNAUTHORIZED=0 node dist/server.js",
    "db:drop-core": "tsx src/scripts/drop-core-collections.ts",
    "db:normalize-erps": "tsx src/scripts/normalize-erp-links.ts",
    "db:normalize-erps:dist": "node dist/scripts/normalize-erp-links.js",
    "test": "tsx --test tests/*.test.ts",
    "test:watch": "tsx --test --watch tests/*.test.ts"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.19.2",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/supertest": "^6.0.3",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^20.19.22",
    "@types/swagger-ui-express": "^4.1.8",
    "mongodb-memory-server": "^10.2.3",
    "supertest": "^7.1.4",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
