{
  "name": "safira-ui",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "APP_ENV=development NODE_ENV=development next dev",
    "dev:production": "APP_ENV=development NODE_ENV=development SAFIRA_API_INTERNAL_URL=https://safira.ailog.com.br NEXT_PUBLIC_API_URL=https://safira.ailog.com.br next dev",
    "clean:next": "rm -rf .next",
    "build": "npm run clean:next && next build",
    "build:production": "npm run clean:next && next build",
    "start": "next start",
    "start:production": "APP_ENV=production NODE_ENV=production next start",
    "lint": "next lint"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@mantine/core": "^8.3.16",
    "@mantine/hooks": "^8.3.16",
    "@mantine/notifications": "^8.3.16",
    "@tanstack/react-query": "^5.90.21",
    "lucide-react": "^0.577.0",
    "next": "^15.5.12",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "recharts": "^3.8.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.12",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
